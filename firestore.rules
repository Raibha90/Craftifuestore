rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // In a real app, you'd check a dedicated 'admins' collection or custom claims.
      // For this MVP, we'll check if the user's document in the 'users' collection has role == 'admin'.
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Rules for User profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && userId == request.auth.uid && (
        incoming().role == 'customer' || incoming().role == 'vendor' || (request.auth.token.email == 'rd14190@gmail.com' && incoming().role == 'admin')
      );
      allow update: if isOwner(userId) && (
        !incoming().diff(existing()).affectedKeys().hasAny(['role'])
      );
      // Admin can update anything including roles
      allow update: if isAdmin();

      // Wishlist subcollection
      match /wishlist/{productId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Rules for Products
    match /products/{productId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin(); // Only admin can create/update/delete
    }

    // Rules for Orders
    match /orders/{orderId} {
      allow create: if isSignedIn() && isOwner(incoming().userId);
      allow read: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow update: if isAdmin(); // Only admin can update order status/tracking
    }

    // Rules for Coupons
    match /coupons/{couponId} {
      allow read: if true; // Public can read to apply at checkout
      allow write: if isAdmin();
    }

    // Rules for Banners
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for CMS Content
    match /cms/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for Jewellery Master (Workbook)
    match /jewellery_master/{sku} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Rules for Reviews
    match /reviews/{reviewId} {
      allow read: if existing().status == 'approved' || isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    // Rules for Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for Vendors
    match /vendors/{vendorId} {
      allow read: if isAdmin() || isOwner(vendorId);
      allow create: if isSignedIn() && vendorId == request.auth.uid && incoming().status == 'pending';
      allow update: if isAdmin() || (isOwner(vendorId) && !incoming().diff(existing()).affectedKeys().hasAny(['status', 'role', 'quality_score']));
      allow delete: if isAdmin();
    }

    // Rules for Events
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for AI Config
    match /aiConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for Commissions
    match /commission_rates/{rateId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /commission_payouts/{payoutId} {
      allow read: if isAdmin() || (isSignedIn() && existing().vendorId == request.auth.uid);
      allow write: if isAdmin();
    }

    // Rules for Contact Inquiries
    match /contact_inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
