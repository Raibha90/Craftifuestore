{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A handcrafted item for sale in the store.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the product." },
        "description": { "type": "string", "description": "A detailed description of the product." },
        "price": { "type": "number", "description": "The price of the product." },
        "category": { "type": "string", "description": "The category the product belongs to (e.g., Necklace, Bangles)." },
        "images": { "type": "array", "description": "URLs of the product images." },
        "material": { "type": "string", "description": "The material used to make the product." },
        "stock": { "type": "integer", "description": "The number of items currently in stock." },
        "isFeatured": { "type": "boolean", "description": "Whether the product should be highlighted on the homepage." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "images", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer's purchase order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who placed the order." },
        "items": { "type": "array", "description": "The products purchased in this order." },
        "totalAmount": { "type": "number", "description": "The total price of the order." },
        "status": { "type": "string", "enum": ["pending", "processed", "shipped", "delivered", "cancelled"], "description": "The current status of the order." },
        "shippingAddress": { "type": "object", "description": "The address where the order will be shipped." },
        "paymentId": { "type": "string", "description": "The Razorpay payment ID." },
        "trackingNumber": { "type": "string", "description": "The tracking number for the shipment." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status", "shippingAddress"]
    },
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "addresses": { "type": "array" }
      }
    },
    "Coupon": {
      "title": "Coupon",
      "description": "A discount coupon for orders.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "discountValue": { "type": "number" },
        "minOrderAmount": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" }
      }
    },
    "Banner": {
      "title": "Homepage Banner",
      "description": "A banner images displayed on the homepage.",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "link": { "type": "string" },
        "order": { "type": "integer" }
      }
    },
    "Setting": {
      "title": "Application Setting",
      "description": "Global application configuration.",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string", "description": "URL of the application logo." },
        "storeName": { "type": "string" },
        "contactEmail": { "type": "string" }
      }
    },
    "WishlistItem": {
      "title": "Wishlist Item",
      "description": "A product saved by a user to their wishlist.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "addedAt"]
    },
    "JewelleryMaster": {
      "title": "Jewellery Master",
      "description": "The single source of truth for all jewellery inventory.",
      "type": "object",
      "properties": {
        "sku": { "type": "string" },
        "productName": { "type": "string" },
        "category": { "type": "string" },
        "subCategory": { "type": "string" },
        "collection": { "type": "string" },
        "metal": { "type": "string" },
        "purity": { "type": "string" },
        "grossWt": { "type": "number" },
        "netWt": { "type": "number" },
        "stoneType": { "type": "string" },
        "stoneWt": { "type": "number" },
        "metalRate": { "type": "number" },
        "stoneValue": { "type": "number" },
        "makingPercent": { "type": "number" },
        "discountPercent": { "type": "number" },
        "stockQty": { "type": "integer" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Sold Out"] },
        "metalValue": { "type": "number" },
        "makingCharges": { "type": "number" },
        "subtotal": { "type": "number" },
        "gst": { "type": "number" },
        "mrp": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "stockValue": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sku", "productName", "category", "metal", "purity", "netWt", "status"]
    },
    "AppEvent": {
      "title": "Application Event",
      "description": "Marketing events and festival celebrations.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "isActive": { "type": "boolean" },
        "bannerUrl": { "type": "string" },
        "offerText": { "type": "string" },
        "aiMessage": { "type": "string" }
      },
      "required": ["name", "date", "isActive"]
    },
    "AIConfig": {
      "title": "AI Configuration",
      "description": "Settings for the AI Personalizer Engine.",
      "type": "object",
      "properties": {
        "promptContext": { "type": "string" },
        "formFieldsVisibility": { "type": "object" },
        "weights": { "type": "object" }
      }
    },
    "CommissionRate": {
      "title": "Commission Rate",
      "description": "Marketplace fee structure per category.",
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "rate": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "CommissionPayout": {
      "title": "Commission Payout",
      "description": "Settlement record for a vendor.",
      "type": "object",
      "properties": {
        "vendorId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid"] },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "ContactInquiry": {
      "title": "Contact Inquiry",
      "description": "Customer enquiries and bulk order requests.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "company": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "type": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/aiConfig/{configId}": {
      "schema": "AIConfig",
      "description": "AI configurations for the personal shopper."
    },
    "/commission_rates/{rateId}": {
      "schema": "CommissionRate",
      "description": "List of commission rates by category."
    },
    "/commission_payouts/{payoutId}": {
      "schema": "CommissionPayout",
      "description": "History of vendor payouts."
    },
    "/contact_inquiries/{inquiryId}": {
      "schema": "ContactInquiry",
      "description": "Customer enquiries and bulk order requests."
    },
    "/events/{eventId}": {
      "schema": "AppEvent",
      "description": "Collection of marketing events."
    },
    "/jewellery_master/{sku}": {
      "schema": "JewelleryMaster",
      "description": "Collection of all jewellery inventory items."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all products."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of all orders."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/users/{userId}/wishlist/{productId}": {
      "schema": "WishlistItem",
      "description": "A user's personal wishlist items."
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Collection of available discount coupons."
    },
    "/banners/{bannerId}": {
      "schema": "Banner",
      "description": "Collection of homepage hero banners."
    },
    "/settings/{settingId}": {
      "schema": "Setting",
      "description": "Global application settings (e.g., /settings/general)."
    }
  }
}
